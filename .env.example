# ── Database ──────────────────────────────────────────────────────────────────
# Provided automatically by Replit PostgreSQL add-on
DATABASE_URL=postgresql://user:password@localhost:5432/vocabulous

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Must be prefixed with VITE_ to be exposed to the browser
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── OpenAI (Phase 1.3 — AI card generation) ──────────────────────────────────
# OPENAI_API_KEY=sk-...
